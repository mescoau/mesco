---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import TeamCard from "@/components/team/TeamCard.astro";
// Content
import { getCollection } from "astro:content";
const allTeam = await getCollection("team");
allTeam.sort((a, b) => {
  const nameA = a.data.name.toLowerCase();
  const nameB = b.data.name.toLowerCase();
  return nameA.localeCompare(nameB);
});
---

<BaseLayout
  seoTitle="Team"
  seoDescription="Meet the directors behind MESCo's engineering systems and compliance frameworks."
>
  <section>
    <Wrapper variant="standard" class="py-24 lg:pt-48">
      <div class="max-w-xl mx-auto text-center text-balance">
        <Kicker class="text-base-600">Leadership Team</Kicker>
        <Text
          tag="h1"
          variant="displayMD"
          class="font-medium tracking-tight mt-12"
        >
          Led by experience. Built on capability.
        </Text>
        <Text tag="p" variant="textLG" class="text-base-600 mt-4">
          MESCo is founded and directed by Kyriah and Adrian McPhee, bringing
          together civil engineering precision and operational HSE knowledge
          built from years of hands-on field experience.
        </Text>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 mt-12 gap-x-8 gap-y-24 max-w-4xl mx-auto">
        {allTeam.map((post) => <TeamCard post={post} />)}
      </div>
    </Wrapper>
  </section>
</BaseLayout>
