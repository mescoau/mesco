---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Sections
import Principles from "@/components/services/Principles.astro";
// Components
import ServiceCard from "@/components/services/ServiceCard.astro";
// Content
import { getCollection } from "astro:content";
const services = await getCollection("services");
services.sort((a, b) => {
  const featuredDiff = (b.data.featured ? 1 : 0) - (a.data.featured ? 1 : 0);
  if (featuredDiff !== 0) return featuredDiff;
  return a.data.title.localeCompare(b.data.title);
});
---

<BaseLayout
  navTransparent={true}
  seoTitle="Services"
  seoDescription="MESCo services that support compliant, audit-ready project delivery."
>
  <section class="bg-brand-blue">
    <Wrapper
      variant="standard"
      class="py-12 pt-48 lg:border-x lg:border-brand-gold"
    >
      <div class="grid grid-cols-1 lg:grid-cols-3 lg:items-end gap-12">
        <div class="max-w-4xl text-balance lg:col-span-2">
          <Kicker class="text-brand-gold">Our Core Services</Kicker>
          <Text
            tag="h1"
            variant="displayMD"
            class="font-medium tracking-tight mt-12 text-white"
          >
            Systems and support across the full project lifecycle
          </Text>
          <Text tag="p" variant="textLG" class="text-base-200 mt-4">
            MESCo covers the full project lifecycle — from mobilisation to
            close-out — ensuring systems are built, maintained and traceable.
            Our frameworks combine engineering precision and practical execution
            with structured compliance, helping contractors meet quality, safety
            and environmental obligations without slowing delivery.
          </Text>
        </div>
      </div>
    </Wrapper>
  </section>

  <section>
    <Wrapper variant="standard" class="py-24 lg:border-x lg:border-brand-gold">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-8 gap-y-24">
        {services.map((service) => <ServiceCard service={service} />)}
      </div>
    </Wrapper>
  </section>
  <Principles />
</BaseLayout>
