---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<BaseLayout
  hideNavigation={true}
  hideFooter={true}
  seoTitle="Page not found"
  seoDescription="The page you’re looking for can’t be found on the MESCo site."
>
  <section class="min-h-dvh flex items-center justify-center bg-accent-950">
    <Wrapper
      variant="standard"
      class="flex flex-col items-center py-32 text-balance"
    >
      <Text
        tag="h1"
        variant="displayXL"
        class="font-bold text-white tracking-tight"
      >
        404
      </Text>
      <Text
        tag="h2"
        variant="displaySM"
        class="text-brand-gold font-medium mt-4"
      >
        This page wasn’t in the scope of works.
      </Text>
      <Text
        tag="p"
        variant="textLG"
        class="text-base-400 mt-4 max-w-xl text-center"
      >
        No management plan, no lot register, no page. Whatever you were looking
        for didn’t make it to mobilisation. Head back to the homepage and
        we’ll get you back on track.
      </Text>
      <Button isLink={true} href="/" size="xs" variant="muted" class="mt-12">
        Back to the homepage
      </Button>
    </Wrapper>
  </section>
</BaseLayout>
