---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Logo from "@/components/assets/Logo.astro";
import AnimatedLogo from "@/components/assets/AnimatedLogo.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="py-24 lg:pt-48">
      <Text tag="h2" variant="displaySM" class="font-medium text-base-900">
        Logo Components
      </Text>

      <!-- AnimatedLogo on dark -->
      <div class="mt-12 bg-base-900 rounded-2xl p-16 flex flex-col items-center gap-8">
        <Text tag="p" variant="textSM" class="text-base-400 uppercase tracking-widest">
          AnimatedLogo (dark bg)
        </Text>
        <AnimatedLogo class="h-20 w-auto text-white" />
        <button
          id="replay-dark"
          class="mt-4 text-sm text-brand-gold border border-brand-gold/30 rounded-full px-4 py-2 hover:bg-brand-gold/10 transition"
        >
          Replay animation
        </button>
      </div>

      <!-- AnimatedLogo on light -->
      <div class="mt-8 bg-white border border-base-200 rounded-2xl p-16 flex flex-col items-center gap-8">
        <Text tag="p" variant="textSM" class="text-base-400 uppercase tracking-widest">
          AnimatedLogo (light bg)
        </Text>
        <AnimatedLogo class="h-20 w-auto text-base-900" />
        <button
          id="replay-light"
          class="mt-4 text-sm text-brand-gold border border-brand-gold/30 rounded-full px-4 py-2 hover:bg-brand-gold/10 transition"
        >
          Replay animation
        </button>
      </div>

      <!-- Static Logo -->
      <div class="mt-8 bg-white border border-base-200 rounded-2xl p-16 flex flex-col items-center gap-8">
        <Text tag="p" variant="textSM" class="text-base-400 uppercase tracking-widest">
          Logo (static)
        </Text>
        <Logo class="h-20 w-auto text-base-900" />
      </div>
    </Wrapper>
  </section>

  <script is:inline>
    document.querySelectorAll('[id^="replay-"]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const container = btn.closest('div');
        const svg = container.querySelector('svg');
        if (!svg) return;
        svg.classList.remove('logo-animate');
        void svg.offsetWidth;
        svg.classList.add('logo-animate');
      });
    });
  </script>
</BaseLayout>
