---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Logo from "@/components/assets/Logo.astro";
import { link } from "@/config/site";
---

<BaseLayout
  hideNavigation={true}
  seoTitle="Message Received"
  seoDescription="Thank you for contacting MESCo."
>
  <div class="min-h-dvh bg-accent-500 flex flex-col">

    <Wrapper variant="standard" class="py-8">
      <a href="/" aria-label="MESCo home">
        <Logo class="h-10 w-auto text-white" />
      </a>
    </Wrapper>

    <Wrapper variant="standard" class="flex-1 flex flex-col justify-center py-20">
      <div class="max-w-xl">
        <Text tag="p" variant="textSM" class="text-brand-gold font-medium uppercase tracking-widest">
          Message received
        </Text>
        <Text tag="h1" variant="display2XL" class="mt-4 text-white font-medium">
          We'll be in touch shortly.
        </Text>
        <Text tag="p" variant="textLG" class="mt-6 text-accent-200">
          One of our directors will respond within one business day. In the meantime, feel free to explore our work.
        </Text>

        <div class="mt-12 flex flex-col sm:flex-row gap-3">
          <Button isLink size="base" variant="muted" href={link("/case-studies")}>
            Case Studies
          </Button>
          <Button isLink size="base" variant="default" href={link("/services")}>
            Our Services
          </Button>
          <Button isLink size="base" variant="default" href={link("/about")}>
            About MESCo
          </Button>
        </div>
      </div>
    </Wrapper>

  </div>
</BaseLayout>
