---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const industries = await getCollection("industries");
industries.sort((a, b) => {
  const orderA = a.data.order ?? 0;
  const orderB = b.data.order ?? 0;
  return orderA - orderB;
});
---

<BaseLayout
  navTransparent={true}
  seoTitle="Industries"
  seoDescription="MESCo systems and compliance support across construction, resources, infrastructure, energy, and government projects."
>
  <section class="bg-brand-blue">
    <Wrapper
      variant="standard"
      class="py-12 pt-48 lg:border-x lg:border-brand-gold"
    >
      <div class="max-w-3xl text-balance">
        <Kicker class="text-brand-gold">Industries</Kicker>
        <Text
          tag="h1"
          variant="displayMD"
          class="font-medium tracking-tight mt-12 text-white"
        >
          Supporting projects across major Australian industries
        </Text>
        <Text tag="p" variant="textLG" class="text-white mt-4">
          MESCo's systems apply across major Australian industries. Whether your
          project is civil construction, mining, infrastructure, energy or
          government-led, we understand the compliance requirements and build
          systems that work for your sector.
        </Text>
      </div>
    </Wrapper>
  </section>

  <section>
    <Wrapper variant="standard" class="py-24 lg:border-x lg:border-brand-gold">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          industries.map((industry) => (
            <article class="rounded bg-base-100 h-full flex flex-col transition-colors duration-300 hover:bg-accent-200 overflow-hidden">
              {industry.data.image && (
                <Image
                  src={industry.data.image.url}
                  alt={industry.data.image.alt}
                  width={800}
                  height={450}
                  class="w-full h-48 object-cover"
                />
              )}
              <div class="p-8 flex flex-col gap-4">
              <Text
                tag="h2"
                variant="textXL"
                class="font-medium text-accent-900"
              >
                {industry.data.title}
              </Text>
              <Text tag="p" variant="textBase" class="text-base-600">
                {industry.data.description}
              </Text>
              {industry.data.focus && (
                <div class="mt-2">
                  <Text tag="p" variant="textSM" class="font-medium text-accent-700">
                    Focus
                  </Text>
                  <Text tag="p" variant="textSM" class="text-base-600 mt-1">
                    {industry.data.focus}
                  </Text>
                </div>
              )}
              {industry.data.typicalProjects && (
                <div class="mt-2">
                  <Text tag="p" variant="textSM" class="font-medium text-accent-700">
                    Typical Projects
                  </Text>
                  <Text tag="p" variant="textSM" class="text-base-600 mt-1">
                    {industry.data.typicalProjects}
                  </Text>
                </div>
              )}
              </div>
            </article>
          ))
        }
      </div>
    </Wrapper>
  </section>
</BaseLayout>
