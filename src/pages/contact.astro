---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import SchemaOrg from "@/components/fundations/head/SchemaOrg.astro";
// Sections
import Hero from "@/components/contact/Hero.astro";
import Form from "@/components/contact/Form.astro";
import Navigate from "@/components/contact/Navigate.astro";
import ReachOut from "@/components/contact/ReachOut.astro";
import Faq from "@/components/contact/Faq.astro";
// Data
import { faqs } from "@/data/faq";

const faqSchema = {
  "@type": "FAQPage",
  mainEntity: faqs.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---
<BaseLayout
  navTransparent={true}
  seoTitle="Contact"
  seoDescription="Contact MESCo to make your next project audit-ready from day one."
>
  <Fragment slot="head">
    <SchemaOrg schema={faqSchema} />
  </Fragment>
  <Hero />
  <Form />
  <Navigate />
  <ReachOut />
  <Faq />
</BaseLayout>
