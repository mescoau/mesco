---
// Assets
import { Image } from "astro:assets";
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import ServiceCard from "@/components/services/ServiceCard.astro";
import SchemaOrg from "@/components/fundations/head/SchemaOrg.astro";
// Config
import { link, siteConfig } from "@/config/site";
import { ORG_ID, SITE_ID } from "@/config/schema";
// Content
import { getCollection } from "astro:content";
const { frontmatter } = Astro.props;
const allServices = await getCollection("services");

const pageUrl = `${siteConfig.url}${Astro.url.pathname}`;
const serviceSchema = [
  {
    "@type": "Service",
    "@id": `${pageUrl}#service`,
    name: frontmatter.title,
    description: frontmatter.description,
    provider: { "@id": ORG_ID },
    url: pageUrl,
    serviceType: "Engineering and Systems Consulting",
    areaServed: { "@type": "Country", name: "Australia" },
    isPartOf: { "@id": SITE_ID },
  },
  {
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: `${siteConfig.url}/` },
      { "@type": "ListItem", position: 2, name: "Services", item: `${siteConfig.url}${link("/services")}` },
      { "@type": "ListItem", position: 3, name: frontmatter.title, item: pageUrl },
    ],
  },
];
const latestServices = allServices
  .filter((service) => service.data.title !== frontmatter.title)
  .slice(0, 2);
---

<BaseLayout
  navTransparent={true}
  seoTitle={frontmatter.title}
  seoDescription={frontmatter.description ?? frontmatter.excerpt}
>
  <Fragment slot="head">
    <SchemaOrg schema={serviceSchema} />
  </Fragment>
  <section class="bg-brand-blue">
    <Wrapper
      variant="standard"
      class="py-12 pt-48 lg:border-x lg:border-brand-gold"
    >
      <div class="max-w-xl text-balance lg:col-span-2">
        <Kicker class="text-base-300">{frontmatter.title}</Kicker>
        <Text
          tag="h1"
          variant="displayMD"
          class="text-white font-medium tracking-tight mt-12"
        >
          {frontmatter.excerpt}
        </Text>
        <Text tag="p" variant="textbas" class="text-base-300 max-w-xl mt-4">
          {frontmatter.description}
        </Text>
      </div>

      <ul role="list" class="space-y-1 list-none mt-12">
        {
          frontmatter.highlights?.map((highlight, index) => (
            <li>
              <Text tag="p" variant="textSM" class="text-base-300">
                {index + 1}. {highlight}
              </Text>
            </li>
          ))
        }
      </ul>
    </Wrapper>
  </section>

  <section>
    <Wrapper variant="paddingless" class="lg:border-x lg:border-brand-gold">
      {frontmatter.video ? (
        <video
          autoplay
          muted
          loop
          playsinline
          poster={typeof frontmatter.image.url === "string" ? frontmatter.image.url : frontmatter.image.url.src}
          class="object-cover object-center w-full max-h-144"
        >
          <source src={frontmatter.video} type="video/mp4" />
        </video>
      ) : (
        <Image
          width={1400}
          height={1400}
          loading="lazy"
          decoding="async"
          src={frontmatter.image.url}
          alt={frontmatter.image.alt || frontmatter.title}
          class="object-cover object-center w-full max-h-144"
        />
      )}
    </Wrapper>
  </section>
  <Wrapper variant="standard" class="py-12 lg:border-x lg:border-brand-gold">
    <Wrapper variant="narrow" class="mx-auto">
      <Wrapper variant="prose">
        <slot />
      </Wrapper>
    </Wrapper>
  </Wrapper>
  {
    latestServices.length > 0 && (
      <section>
        <Wrapper variant="standard" class="py-24 lg:border-x lg:border-brand-gold">
          <div class="flex flex-col md:flex-row gap-4 md:items-center justify-between">
            <Text
              tag="h2"
              variant="displaySM"
              class="font-medium  tracking-tight   text-accent-900"
            >
              Latest services
            </Text>
            <Button
              isLink
              size="xs"
              variant="muted"
              href={link("/services")}
              class="w-fit"
            >
              See all services
            </Button>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 mt-12 lg:mt-24 gap-x-8 gap-y-24">
            {latestServices.map((service) => (
              <ServiceCard service={service} />
            ))}
          </div>
        </Wrapper>
      </section>
    )
  }
</BaseLayout>
