---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import SchemaOrg from "@/components/fundations/head/SchemaOrg.astro";
// Config
import { siteConfig } from "@/config/site";
import { SITE_ID } from "@/config/schema";
const { frontmatter } = Astro.props;

const pageUrl = `${siteConfig.url}${Astro.url.pathname.replace(/\/+$/, "")}`;
const legalSchema = [
  {
    "@type": "WebPage",
    "@id": `${pageUrl}#webpage`,
    name: frontmatter.page,
    url: pageUrl,
    isPartOf: { "@id": SITE_ID },
    ...(frontmatter.pubDate
      ? { dateModified: new Date(frontmatter.pubDate).toISOString() }
      : {}),
  },
  {
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: siteConfig.url },
      { "@type": "ListItem", position: 2, name: frontmatter.page, item: pageUrl },
    ],
  },
];
---

<BaseLayout
  navTransparent={true}
  seoTitle={frontmatter.page}
>
  <Fragment slot="head">
    <SchemaOrg schema={legalSchema} />
  </Fragment>
  <section class="bg-accent-800">
    <Wrapper
      variant="standard"
      class="py-12 pt-48 lg:border-x lg:border-brand-gold/10"
    >
      <div class="max-w-xl mx-auto text-center text-balance lg:col-span-2">
        <Kicker class="text-base-300">LEgal</Kicker>
        <Text
          tag="h1"
          variant="displayMD"
          class="font-medium tracking-tight mt-12 text-white"
        >
          {frontmatter.page}
        </Text>
        <Text tag="p" variant="textLG" class="text-base-400 mt-4">
          Last updated on
          <time datetime={new Date(frontmatter.pubDate).toISOString()}>
            {
              new Date(frontmatter.pubDate).toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "2-digit",
              })
            }
          </time>
        </Text>
      </div>
    </Wrapper>
  </section>
  <section>
    <Wrapper variant="standard" class="py-12">
      <Wrapper variant="narrow" class="mx-auto">
        <Wrapper variant="prose">
          <slot />
        </Wrapper>
      </Wrapper>
    </Wrapper>
  </section>
</BaseLayout>
