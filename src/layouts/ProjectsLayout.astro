---
// Assets
import { Image } from "astro:assets";
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import ProjectCardSmall from "@/components/projects/ProjectCardSmall.astro";
import Button from "@/components/fundations/elements/Button.astro";
import SchemaOrg from "@/components/fundations/head/SchemaOrg.astro";
// Config
import { link, siteConfig } from "@/config/site";
import { ORG_ID, SITE_ID } from "@/config/schema";
// Content
import { getCollection } from "astro:content";
const { frontmatter } = Astro.props;
const meta = [frontmatter.category, frontmatter.location, frontmatter.duration]
  .filter(Boolean)
  .join(" • ");
const allProjects = await getCollection("projects");
const latestProjects = allProjects
  .filter((project) => project.data.title !== frontmatter.title)
  .slice(0, 3);

const pageUrl = `${siteConfig.url}${Astro.url.pathname}`;
const projectSchema = [
  {
    "@type": "Article",
    "@id": `${pageUrl}#article`,
    headline: frontmatter.title,
    description: frontmatter.description,
    author: { "@id": ORG_ID },
    publisher: { "@id": ORG_ID },
    url: pageUrl,
    isPartOf: { "@id": SITE_ID },
    ...(frontmatter.year ? { datePublished: String(frontmatter.year) } : {}),
    ...(frontmatter.client ? { sourceOrganization: frontmatter.client } : {}),
    ...(frontmatter.category
      ? { about: { "@type": "Thing", name: frontmatter.category } }
      : {}),
  },
  {
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: `${siteConfig.url}/` },
      { "@type": "ListItem", position: 2, name: "Case Studies", item: `${siteConfig.url}${link("/case-studies")}` },
      { "@type": "ListItem", position: 3, name: frontmatter.title, item: pageUrl },
    ],
  },
];
---

<BaseLayout
  navTransparent={true}
  seoTitle={frontmatter.title}
  seoDescription={frontmatter.description}
>
  <section class="bg-accent-800">
    <Wrapper
      variant="standard"
      class="py-12 pt-48 lg:border-x lg:border-brand-gold"
    >
      <div class="grid grid-cols-1 lg:grid-cols-3 lg:items-end gap-12">
        <div class="max-w-xl text-balance lg:col-span-2">
          <Kicker class="text-base-300"> {meta}</Kicker>
          <Text
            tag="h1"
            variant="displayMD"
            class="text-white font-medium tracking-tight mt-12"
          >
            {frontmatter.title}
          </Text>
          <Text tag="p" variant="textLG" class="text-white max-w-xl mt-4">
            {frontmatter.description}
          </Text>
        </div>
        {frontmatter.services && (
          <ul role="list" class="space-y-1 list-none">
            {
              frontmatter.services.map((service) => (
                <li>
                  <Text tag="p" variant="textBase" class="text-base-400 ">
                    {service}
                  </Text>
                </li>
              ))
            }
          </ul>
        )}
      </div>
    </Wrapper>
    {frontmatter.cover && (
      <Wrapper
        variant="standard"
        class="py-8 lg:border-x lg:border-brand-gold border-t border-brand-gold"
      >
        <Image
          width={1400}
          height={1400}
          loading="lazy"
          decoding="async"
          src={frontmatter.cover.url}
          alt={frontmatter.cover.alt || frontmatter.title}
          class="object-cover object-center w-full max-h-120"
        />
      </Wrapper>
    )}
  </section>
  {frontmatter.metrics && frontmatter.metrics.length > 0 && (
    <section>
      <Wrapper variant="standard" class="py-24 lg:border-x lg:border-brand-gold">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
          {
            frontmatter.metrics.map((metric) => (
              <div>
                <Text
                  tag="p"
                  variant="displayLG"
                  class="text-accent-900 italic font-medium "
                >
                  {metric.value}
                </Text>
                <Text tag="p" variant="textLG" class="text-base-600 mt-2">
                  {metric.label}
                </Text>
              </div>
            ))
          }
        </div>
      </Wrapper>
    </section>
  )}
  <Wrapper variant="standard" class="py-12 lg:border-x lg:border-brand-gold">
    <Wrapper variant="narrow" class="mx-auto">
      <Wrapper variant="prose">
        <slot />
      </Wrapper>
    </Wrapper>
  </Wrapper>
  {
    latestProjects.length > 0 && (
      <section>
        <Wrapper variant="standard" class="py-24 lg:border-x lg:border-brand-gold">
          <div class="flex flex-col md:flex-row gap-4 md:items-center justify-between">
            <Text
              tag="h2"
              variant="displaySM"
              class="font-medium  tracking-tight   text-accent-900"
            >
              Other case studies
            </Text>
            <Button
              isLink
              size="xs"
              variant="muted"
              href={link("/case-studies")}
              class="w-fit"
            >
              See all case studies
            </Button>
          </div>
          <div class="flex flex-col mt-12 lg:mt-24 space-y-8">
            {latestProjects.map((project) => (
              <ProjectCardSmall project={project} hideImage={true} />
            ))}
          </div>
        </Wrapper>
      </section>
    )
  }
</BaseLayout>
