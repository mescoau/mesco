---
// Icons
import Close from "@/components/fundations/icons/Close.astro";
import Burger from "@/components/fundations/icons/Burger.astro";
// Fundations
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import Search from "@/components/global/Search.astro";
import MobileNavigation from "@/components/global/navigation/MobileNavigation.astro";
// Config
import { link } from "@/config/site";
// Allow pages/layouts to opt-in to transparent behavior; default is solid
const { transparent } = Astro.props as { transparent?: boolean };
const isTransparent = !!transparent;
const navLinks = [
  { label: "About", href: link("/about") },
  { label: "Values", href: link("/values") },
  { label: "Services", href: link("/services") },
  { label: "Case Studies", href: link("/case-studies") },
  { label: "Industries", href: link("/industries") },
  { label: "Team", href: link("/team") },
];
---

<nav
  class={`fixed w-full top-0 z-50 transition-all duration-300 border-b border-brand-gold ${isTransparent ? "nav-transparent" : "bg-white/80 backdrop-blur-xl"}`}
  data-nav
  data-swap={isTransparent ? "true" : "false"}
  transition:persist="nav"
>
  <Wrapper variant="standard" class="relative lg:border-x lg:border-brand-gold">
    <div class="py-4 grid grid-cols-2 lg:grid-cols-[1fr_auto_1fr] items-center gap-x-6">
      <a
        href="/"
        aria-label="Home"
        data-logo
        class={`focus:outline-none text-2xl font-medium flex items-center gap-2 ${isTransparent ? "text-white" : "text-base-800"}`}
      >
        <span class="sr-only">Home</span>
        <img
          src={isTransparent ? "/brand/mesco_svg_white.svg" : "/brand/mesco_svg_blue.svg"}
          alt="MESCo"
          width="719"
          height="270"
          loading="eager"
          decoding="async"
          class="h-12 w-auto transition-all duration-300"
          data-nav-logo
          data-logo-image
          data-dark-src="/brand/mesco_svg_white.svg"
          data-light-src="/brand/mesco_svg_blue.svg"
        />
      </a>

      <!-- Desktop liquid glass nav pill -->
      <div
        class="hidden lg:flex items-center gap-1 py-1.5 px-1.5 rounded-full relative
          bg-white/10 backdrop-blur-2xl
          border border-white/20
          shadow-[inset_0_1px_0_rgba(255,255,255,0.25),0_2px_12px_rgba(0,0,0,0.08)]"
        data-glass-nav
      >
        <!-- Gliding hover pill -->
        <span
          class="absolute rounded-full pointer-events-none opacity-0"
          style="transition: left 180ms cubic-bezier(0.4,0,0.2,1), top 180ms cubic-bezier(0.4,0,0.2,1), width 180ms cubic-bezier(0.4,0,0.2,1), height 180ms cubic-bezier(0.4,0,0.2,1), opacity 150ms ease; backdrop-filter: blur(8px); background: rgba(255,255,255,0.22); box-shadow: inset 0 1px 0 rgba(255,255,255,0.4);"
          data-hover-pill
          aria-hidden="true"
        ></span>

        {
          navLinks.map((l) => (
            <a
              href={l.href}
              class={`relative z-10 text-sm px-4 py-1.5 rounded-full transition-colors duration-150 ${isTransparent ? "text-white" : "text-base-800"}`}
              data-primary-link
            >
              {l.label}
            </a>
          ))
        }
      </div>

      <div class="hidden lg:flex gap-2 items-center justify-end">
        <Search />
        <Button
          isLink
          size="xs"
          variant="muted"
          href={link("/contact")}
          class="hidden lg:flex"
        >
          Contact MESCo
        </Button>
      </div>
      <button
        class={`lg:hidden ml-auto flex relative ${isTransparent ? "text-white" : "text-base-800"}`}
        aria-controls="mobile-menu"
        aria-expanded="false"
        data-menu-button
      >
        <span class="sr-only">Open main menu</span>
        <span
          class="block"
          style="display: var(--burger-display, block);"
          data-burger
        >
          <Burger size="xl" slot="icon" />
        </span>
        <span
          class="hidden"
          style="display: var(--close-display, none);"
          data-close
        >
          <Close size="xl" slot="icon" />
        </span>
      </button>
    </div>
    <!-- Mobile Menu -->
    <MobileNavigation navLinks={navLinks} />
  </Wrapper>
</nav>
