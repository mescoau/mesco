---
// Assets
import Logo from "@/components/assets/Logo.astro";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
type LinkItem = {
  label: string;
  href: string;
};

type LinkSection = {
  title: string;
  links: LinkItem[];
};

const linkSections: LinkSection[] = [
  {
    title: "Company",
    links: [
      { label: "About", href: "/about" },
      { label: "Industries", href: "/industries" },
      { label: "Team", href: "/team" },
      { label: "Contact", href: "/contact" },
    ],
  },
  {
    title: "Services",
    links: [
      { label: "Project Start-Up Services", href: "/services/project-start-up-services" },
      { label: "Automated Engineering Systems", href: "/services/automated-engineering-systems-and-qaqc-frameworks" },
      { label: "Engineering Administration", href: "/services/engineering-administration-and-project-support" },
      { label: "HSE Systems", href: "/services/health-safety-and-environmental-systems" },
      { label: "ISO Systems & Audit Support", href: "/services/iso-systems-and-audit-support" },
      { label: "Project Close-Out Services", href: "/services/project-close-out-services" },
    ],
  },
  {
    title: "Resources",
    links: [
      { label: "Case Studies", href: "/case-studies" },
      { label: "Services", href: "/services" },
      { label: "Privacy", href: "/legal/privacy" },
    ],
  },
];

const contactDetails = {
  email: "adrian@mesco.au",
  phone: "+61 409 729 303",
  address: "Perth, WA",
  hours: ["Mon-Fri: 8:00 AM - 5:00 PM"],
};

const legalLinks: LinkItem[] = [
  { label: "Privacy", href: "/legal/privacy" },
  { label: "Terms", href: "/legal/terms" },
  { label: "Cookies", href: "/legal/cookies" },
];
---

<footer class="relative isolate overflow-hidden bg-accent-950 text-base-100">
  <div class="absolute inset-0 z-0 pointer-events-none">
    <video autoplay muted loop playsinline class="size-full object-cover">
      <source src="/footer.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-accent-950/75"></div>
  </div>

  <Wrapper
    variant="standard"
    class="relative z-10 lg:border-brand-gold py-8 border-b lg:border-x"
  >
    <div
      class="flex flex-col gap-8 p-8 lg:flex-row lg:items-end lg:justify-between bg-accent-950 rounded"
    >
      <div class="max-w-xl text-balance">
        <Logo class="h-12 text-white" />

        <Text tag="p" variant="textLG" class="text-white font-medium mt-24">
          Bridging the gap between design and delivery with structured,
          audit-ready project systems.
        </Text>
      </div>
      <div class="flex flex-wrap gap-2 sm:items-center">
        <Button
          isLink
          size="xs"
          variant="default"
          href={`mailto:${contactDetails.email}`}
        >
          {contactDetails.email}
        </Button>
        <Button
          isLink
          size="xs"
          variant="muted"
          href={`tel:${contactDetails.phone.replace(/[^\d+]/g, "")}`}
        >
          {contactDetails.phone}
        </Button>
      </div>
    </div>
  </Wrapper>
  <Wrapper
    variant="standard"
    class="relative pt-8 pb-12 lg:border-x lg:border-brand-gold space-y-12 z-10"
  >
    <div class="grid gap-x-8 sm:grid-cols-2 lg:grid-cols-4 gap-y-24">
      {
        linkSections.map((section) => (
          <div>
            <Text
              tag="p"
              variant="textXS"
              class="uppercase font-medium  text-white"
            >
              {section.title}
            </Text>
            <div class="space-y-2 text-sm mt-12">
              {section.links.map((link) => (
                <a
                  href={link.href}
                  class="block text-base-200 transition hover:text-accent-300 w-fit"
                >
                  {link.label}
                </a>
              ))}
            </div>
          </div>
        ))
      }

      <div>
        <Text tag="p" variant="textXS" class="uppercase font-medium text-white">
          Contact
        </Text>
        <div class="mt-12">
          {contactDetails.hours.map((h) => (
            <Text tag="p" variant="textSM" class="text-base-200">{h}</Text>
          ))}
          <address>
            <p class="whitespace-pre-line leading-relaxed mt-2">
              {contactDetails.address}
            </p>
          </address>
        </div>
      </div>
    </div>

    <div class="border-t border-brand-gold pt-8 -mx-8 px-8">
      <div
        class="flex flex-col gap-8 md:flex-row md:items-start md:justify-between"
      >
        <div class="flex flex-col gap-2">
          <Text tag="p" variant="textSM" class="text-base-300">
            © {new Date().getFullYear()} MESCo. All rights reserved.
          </Text>
          <Text tag="p" variant="textXS" class="text-base-400 credit-text">
            Another <a href="https://unpopular.au" target="_blank" rel="noopener noreferrer" class="credit-link">Unpopular</a> website by <a href="https://joshwithers.au" target="_blank" rel="noopener noreferrer" class="credit-link">Josh Withers</a>
          </Text>
        </div>
        <div class="flex flex-wrap gap-4 text-white text-sm">
          {
            legalLinks.map((link) => (
              <a href={link.href} class="hover:text-accent-300 transition">
                {link.label}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </Wrapper>
</footer>
