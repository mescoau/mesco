---
// Assets
import { Image } from "astro:assets";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import UnderlinedLink from "@/components/fundations/elements/UnderlinedLink.astro";
// Config
import { link } from "@/config/site";
// Content
const { title, description, url, image, video } = {
  url: link("/services/" + Astro.props.service.id),
  title: Astro.props.service.data.title,
  description: Astro.props.service.data.description,
  image: Astro.props.service.data.image.url,
  video: Astro.props.service.data.video,
};
const posterSrc = typeof image === "string" ? image : image.src;
---

<article>
  <a href={url} title={`View service: ${title}`}>
    {video ? (
      <video
        autoplay
        muted
        loop
        playsinline
        poster={posterSrc}
        class="object-cover object-center w-full aspect-4/3 rounded"
      >
        <source src={video} type="video/mp4" />
      </video>
    ) : (
      <Image
        src={image}
        alt={title}
        width={image.width}
        height={image.height}
        widths={[360, 480, 640, 800]}
        sizes="(min-width: 1024px) 42rem, 100vw"
        formats={["avif", "webp"]}
        loading="lazy"
        decoding="async"
        class="object-cover object-center w-full aspect-4/3 rounded"
      />
    )}
  </a>
  <div class="mt-4">
    <Text tag="h3" variant="textXL" class="font-medium text-accent-900">
      <a href={url}>{title}</a>
    </Text>
    <Text tag="p" variant="textBase" class="text-base-600 mt-1 line-clamp-2">
      {description}
    </Text>
    <UnderlinedLink
      href={url}
      variant="dark"
      title={`View service: ${title}`}
      class="mt-4"
    >
      Read further</UnderlinedLink
    >
  </div>
</article>
