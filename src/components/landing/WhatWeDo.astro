---
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
const focusAreas = [
  {
    title: "Systems and documentation",
    description:
      "Frameworks, templates, and registers that keep WHS, quality, and project records organised and easy to audit.",
  },
  {
    title: "Support for delivery teams",
    description:
      "Hands-on support for project managers, engineers, and supervisors so systems work in both the office and on site.",
  },
];
---

<section>
  <Wrapper variant="standard" class="py-24">
    <div class="max-w-3xl">
      <Kicker class="text-base-600">Our focus</Kicker>
      <Text
        tag="h2"
        variant="displayMD"
        class="font-medium tracking-tight mt-12 text-balance"
      >
        <span class="text-accent-900">We are here </span>
        <span class="text-accent-500">
          to put structured systems, documentation, and compliance support
          around how projects are planned and delivered.
        </span>
      </Text>
      <Text tag="p" variant="textLG" class="text-base-600 mt-4">
        Our work focuses on bridging the gap between design consultants and
        contractors, giving project teams practical tools, responsibilities, and
        workflows they can rely on every day.
      </Text>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mt-12 lg:mt-24">
      {
        focusAreas.map((area) => (
          <div>
            <Text
              tag="h3"
              variant="textXL"
              class="text-accent-900 font-medium "
            >
              {area.title}
            </Text>
            <Text tag="p" variant="textLG" class="text-base-600 mt-2">
              {area.description}
            </Text>
          </div>
        ))
      }
    </div>
  </Wrapper>
</section>
