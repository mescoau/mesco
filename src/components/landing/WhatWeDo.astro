---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import { link } from "@/config/site";

const slugOrder = [
  "project-start-up-services",
  "automated-engineering-systems-and-qaqc-frameworks",
  "engineering-administration-and-project-support",
  "health-safety-and-environmental-systems",
  "iso-systems-and-audit-support",
  "project-close-out-services",
  "short-term-fill-ins-and-technical-support",
  "project-familiarisation-and-delivery-tools",
];

const allServices = await getCollection("services");
const services = slugOrder
  .map((slug) => allServices.find((s) => s.id === slug))
  .filter(Boolean);
---

<section>
  <Wrapper variant="standard" class="py-24 lg:border-x border-t lg:border-brand-gold">
    <div class="max-w-3xl">
      <Kicker class="text-base-600">Our Services</Kicker>
      <Text
        tag="h2"
        variant="displayMD"
        class="font-medium tracking-tight mt-12 text-balance"
      >
        <span class="text-accent-900">Core Services Snapshot</span>
      </Text>
      <Text tag="p" variant="textLG" class="text-base-600 mt-4">
        MESCo covers the full project lifecycle — from mobilisation to close-out — ensuring systems are built, maintained and traceable.
      </Text>
    </div>
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-12 mt-12 lg:mt-24"
    >
      {
        services.map((service) => (
          <a href={link(`/services/${service.id}`)} class="group block h-full">
            <div class="h-full flex flex-col justify-between bg-base-100 rounded-lg hover:bg-accent-200 transition-colors duration-300 overflow-hidden">
              <div>
                <Image
                  src={service.data.image.url}
                  alt={service.data.image.alt}
                  width={400}
                  height={250}
                  class="w-full h-40 object-cover"
                />
                <div class="p-6">
                  <Text
                    tag="h3"
                    variant="textLG"
                    class="text-accent-900 font-medium group-hover:text-accent-700"
                  >
                    {service.data.title}
                  </Text>
                  <Text tag="p" variant="textSM" class="text-base-600 mt-2">
                    {service.data.excerpt || service.data.description}
                  </Text>
                </div>
              </div>
              <div class="px-6 pb-6 flex justify-end">
                 <span class="text-brand-gold group-hover:translate-x-1 transition-transform duration-300">&rarr;</span>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </Wrapper>
</section>
