---
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import { link } from "@/config/site";
const services = [
  {
    title: "Project Start-Up Services",
    outcome: "Project Ready Systems: Management plans, project procedures, QA/QC frameworks, lot registers, WHSMPs and risk registers — all controlled, documented, ready to mobilise.",
    slug: "project-start-up-services",
  },
  {
    title: "Automated Engineering Systems & QA/QC Frameworks",
    outcome: "Controlled QA/QC Systems: Digital lot registers, ITPs, NCR and test workflows designed to connect design intent with site delivery — documented, accurate and fully traceable.",
    slug: "automated-engineering-systems-and-qaqc-frameworks",
  },
  {
    title: "Engineering Administration & Project Support",
    outcome: "Structured Engineering Administration: Daily coordination, document control, ITP administration, lot tracking, test record management, QA reporting and close-out support.",
    slug: "engineering-administration-and-project-support",
  },
  {
    title: "Health, Safety & Environmental Systems",
    outcome: "Integrated Safety: Integrated WHS and environmental frameworks aligned to ISO 45001 & 14001.",
    slug: "health-safety-and-environmental-systems",
  },
  {
    title: "ISO Systems & Audit Support",
    outcome: "Proven Compliance: Gap assessments, internal audits, readiness reviews and automated action tracking.",
    slug: "iso-systems-and-audit-support",
  },
  {
    title: "Project Close-Out Services",
    outcome: "Expert Handover: Digital MDRs, test record collation, turnover folders and structured close-out documentation.",
    slug: "project-close-out-services",
  },
  {
    title: "Short-Term Fill-Ins & Technical Support",
    outcome: "Focused Capability: On-demand engineering, HSE, or advanced administration coverage using clear, efficient, and consistent work practices.",
    slug: "short-term-fill-ins-and-technical-support",
  },
  {
    title: "Project Familiarisation & Delivery Tools",
    outcome: "Crew Clarity: Supervisor cheat sheets, work packs, lot boundary plans, and quality acceptance criteria.",
    slug: "project-familiarisation-and-delivery-tools",
  },
];
---

<section>
  <Wrapper variant="standard" class="py-24 lg:border-x border-t lg:border-brand-gold">
    <div class="max-w-3xl">
      <Kicker class="text-base-600">Our Services</Kicker>
      <Text
        tag="h2"
        variant="displayMD"
        class="font-medium tracking-tight mt-12 text-balance"
      >
        <span class="text-accent-900">Core Services Snapshot</span>
      </Text>
      <Text tag="p" variant="textLG" class="text-base-600 mt-4">
        MESCo covers the full project lifecycle — from mobilisation to close-out — ensuring systems are built, maintained and traceable.
      </Text>
    </div>
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-12 mt-12 lg:mt-24"
    >
      {
        services.map((service) => (
          <a href={link(`/services/${service.slug}`)} class="group block h-full">
            <div class="h-full flex flex-col justify-between p-6 bg-base-100 rounded-lg hover:bg-accent-200 transition-colors duration-300">
              <div>
                <Text
                  tag="h3"
                  variant="textLG"
                  class="text-accent-900 font-medium group-hover:text-accent-700"
                >
                  {service.title}
                </Text>
                <Text tag="p" variant="textSM" class="text-base-600 mt-2">
                  {service.outcome}
                </Text>
              </div>
              <div class="mt-4 flex justify-end">
                 <span class="text-brand-gold group-hover:translate-x-1 transition-transform duration-300">&rarr;</span>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </Wrapper>
</section>
