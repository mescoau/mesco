---
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
const items = [
  {
    title: "Execution-First",
    description: "We don't just advise — we help deliver.",
  },
  {
    title: "Intelligent Automation",
    description: "Streamlined workflows and live tracking reduce admin and improve control.",
  },
  {
    title: "Structured & Compliant",
    description: "Each framework follows ISO 9001 / 45001 / 14001 and is customised to client and project requirements.",
  },
  {
    title: "Built for Site",
    description: "Systems tested and refined in live project environments.",
  },
  {
    title: "Lean & Scalable",
    description: "Direct access to decision-makers; no unnecessary layers.",
  },
  {
    title: "Traceable by Design",
    description: "Every record version-controlled, linked and verifiable.",
  },
];
---

<section class="bg-base-50">
  <Wrapper variant="standard" class="py-24 pb-48 lg:border-x lg:border-brand-gold border-t">
    <div class="max-w-3xl">
      <Kicker class="text-base-600">The MESCo Advantage</Kicker>
      <Text
        tag="h2"
        variant="displayMD"
        class="font-medium tracking-tight mt-12 text-balance"
      >
        <span class="text-accent-900">Why We're Different</span>
      </Text>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mt-12 lg:mt-24">
      {
        items.map((item) => (
          <div class="p-8 bg-white rounded-lg bg-base-100 rounded-lg hover:bg-accent-200">
            <Text
              tag="h3"
              variant="textLG"
              class="text-accent-900 font-medium"
            >
              {item.title}
            </Text>
            <Text tag="p" variant="textBase" class="text-base-600 mt-2">
              {item.description}
            </Text>
          </div>
        ))
      }
    </div>
  </Wrapper>
</section>
