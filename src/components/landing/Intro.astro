---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<section class="bg-white">
  <Wrapper
    variant="standard"
    class="py-24 lg:border-x lg:border-brand-gold"
  >
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
      <!-- The Problem -->
      <div>
        <Kicker class="text-base-500">The Problem</Kicker>
        <Text
          tag="h2"
          variant="displayMD"
          class="font-medium tracking-tight mt-8 text-accent-950 text-balance"
        >
          Projects often start before systems are ready
        </Text>
        <Text tag="p" variant="textLG" class="text-base-600 mt-6">
          Engineers often scramble to build registers, gather documentation, and
          meet compliance requirements after work has already begun. This
          reactive approach causes unnecessary stress, operational inefficiency,
          and significant audit risk.
        </Text>
      </div>

      <!-- How MESCo Fixes It -->
      <div>
        <Kicker class="text-accent-600">How MESCo Fixes It</Kicker>
        <Text
          tag="h2"
          variant="displayMD"
          class="font-medium tracking-tight mt-8 text-accent-950 text-balance"
        >
          Systems set up before mobilisation
        </Text>
        <Text tag="p" variant="textLG" class="text-base-600 mt-6">
          MESCo steps in early—before mobilisation—to set up QA/QC, HSE, and
          compliance systems. We ensure the difference between "catching up" and
          being <strong>audit-ready from day one</strong>.
        </Text>
      </div>
    </div>
  </Wrapper>
</section>
