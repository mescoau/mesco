---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<section class="bg-white">
  <Wrapper
    variant="standard"
    class="py-24 lg:border-x lg:border-brand-gold"
  >
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
      <!-- The Problem -->
      <div>
        <Kicker class="text-base-500">The Problem</Kicker>
        <Text
          tag="h2"
          variant="displayMD"
          class="font-medium tracking-tight mt-8 text-accent-950 text-balance"
        >
          Projects start under pressure — and systems get built on the fly
        </Text>
        <Text tag="p" variant="textLG" class="text-base-600 mt-6">
          Most projects start under pressure. Design packages land late, registers aren't ready, and the team is already on site. Engineers end up building systems as they go, juggling ITPs, test records, NCRs and handover requirements. Without structure, compliance becomes reactive, documentation falls behind, and handover turns into a scramble instead of a process.
        </Text>
      </div>

      <!-- How MESCo Fixes It -->
      <div>
        <Kicker class="text-accent-600">How MESCo Fixes It</Kicker>
        <Text
          tag="h2"
          variant="displayMD"
          class="font-medium tracking-tight mt-8 text-accent-950 text-balance"
        >
          Structured systems — ready before mobilisation
        </Text>
        <Text tag="p" variant="textLG" class="text-base-600 mt-6">
          MESCo steps in early — before mobilisation — to build the QA/QC, HSE, and compliance systems your project needs. We translate contract and client requirements into documented, audit-ready frameworks that site teams can actually use and follow from <strong>day one</strong>.
        </Text>
      </div>
    </div>
  </Wrapper>
</section>
