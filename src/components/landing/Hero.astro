---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
const stats = [
  { value: "Systems-first", label: "Approach on every project" },
  { value: "Audit-ready", label: "Documentation and handover" },
  { value: "Compliance-led", label: "Processes across disciplines" },
  { value: "Practical support", label: "For site and office teams" },
];
---

<section class="relative min-h-[80dvh] flex flex-col">
  <div class="absolute inset-0 z-0">
    <video autoplay muted loop playsinline class="size-full object-cover">
      <source src="/night.mp4" type="video/mp4" />
    </video>
    <div
      aria-hidden="true"
      class="absolute pointer-events-none inset-0 bg-accent-950/60"
    >
    </div>
  </div>
  <div class="relative z-10 flex-1 flex flex-col">
    <Wrapper
      variant="standard"
      class="flex-1 flex flex-col justify-end py-12 lg:pb-12 pt-24 lg:border-x lg:border-white/10"
    >
      <div class="max-w-xl text-balance">
        <Kicker class="text-white">Bridging design and delivery</Kicker>
        <Text
          tag="h1"
          variant="displayLG"
          class="text-white font-medium tracking-tight mt-12"
        >
          Bridging the gap between design and delivery
        </Text>
        <Text tag="p" variant="textLG" class="text-white max-w-xl mt-4">
          Structured systems and compliance support for clean, auditable project
          delivery.
        </Text>
      </div>
    </Wrapper>
    <div class="relative z-10 border-t border-white/10">
      <Wrapper variant="standard" class="py-8 lg:border-x lg:border-white/10">
        <div
          class="grid grid-cols-2 md:grid-cols-4 gap-y-4 gap-x-8 lg:max-w-3xl lg:ml-auto"
        >
          {
            stats.map((stat) => (
              <div>
                <Text
                  tag="p"
                  variant="displayLG"
                  class="text-white italic font-medium"
                >
                  {stat.value}
                </Text>
                <Text tag="p" variant="textSM" class="text-base-400 mt-1">
                  {stat.label}
                </Text>
              </div>
            ))
          }
        </div>
      </Wrapper>
    </div>
  </div>
</section>
