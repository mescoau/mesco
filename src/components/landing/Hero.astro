---
import { getImage } from "astro:assets";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import heroFallback from "@/images/failsafe-hero.jpg";
const heroDesktopFallback = await getImage({
  src: heroFallback,
  width: 1280,
  format: "webp",
  quality: 30,
});
const stats = [
  { value: "Systems-first", label: "Approach from mobilisation to close-out" },
  { value: "Audit-ready", label: "Documentation and compliance" },
  { value: "ISO-aligned", label: "9001 / 45001 / 14001 frameworks" },
  { value: "Field-tested", label: "Built from experience, delivered with intent" },
];
---

<section data-hero-section class="relative min-h-[80dvh] flex flex-col bg-accent-950 lg:border-b lg:border-brand-gold">
  <div
    class="absolute inset-0 z-0 hero-fallback"
    style={`--hero-fallback-image: url('${heroDesktopFallback.src}')`}
  >
    <video
      data-hero-video
      muted
      playsinline
      webkit-playsinline
      preload="none"
      aria-hidden="true"
      disablepictureinpicture
      controlslist="nodownload noplaybackrate noremoteplayback"
      class="size-full object-cover opacity-0 transition-opacity duration-500"
      data-src="/videos/hero.mp4"
    ></video>
    <div
      aria-hidden="true"
      class="absolute pointer-events-none inset-0 bg-accent-950/60"
    >
    </div>
  </div>
  <div class="relative z-10 flex-1 flex flex-col">
    <Wrapper
      variant="standard"
      class="flex-1 flex flex-col justify-end py-12 lg:pb-12 pt-24 lg:border-x lg:border-brand-gold"
    >
      <div class="max-w-xl text-balance">
        <!--<Kicker class="text-white">McPhee Engineering Systems</Kicker> -->
        <Text
          tag="h1"
          variant="displayLG"
          class="text-white font-medium tracking-normal mt-12"
        >
          MESCo bridges the gap between design and delivery — turning drawings, specifications and client requirements into structured systems the site team can actually deliver
        </Text>
        <Text tag="p" variant="textLG" class="text-white max-w-xl mt-4">
          MESCo builds practical, field-ready QA/QC and compliance frameworks for civil, mining and infrastructure projects — giving contractors clarity, control and confidence from mobilisation to close-out.
        </Text>
      </div>
    </Wrapper>
    <div class="relative z-10 border-t border-brand-gold">
      <Wrapper variant="standard" class="py-8 lg:border-x lg:border-brand-gold">
        <div
          class="grid grid-cols-2 md:grid-cols-4 gap-y-4 gap-x-8 w-full"
        >
          {
            stats.map((stat) => (
              <div>
                <Text
                  tag="p"
                  variant="displayMD"
                  class="text-white italic font-medium"
                >
                  {stat.value}
                </Text>
                <Text tag="p" variant="textSM" class="text-base-400 mt-1">
                  {stat.label}
                </Text>
              </div>
            ))
          }
        </div>
      </Wrapper>
    </div>
  </div>
</section>

<!-- Mobile media toggle: visible only below lg, for performance testing -->
<button
  id="hero-mobile-toggle"
  class="lg:hidden fixed bottom-4 right-4 z-50 bg-brand-gold text-accent-950 text-xs font-semibold px-3 py-2 rounded-full shadow-lg"
  aria-label="Toggle mobile background media"
>
  Show BG
</button>

<script>
  const section = document.querySelector<HTMLElement>('[data-hero-section]');
  const video = document.querySelector<HTMLVideoElement>('video[data-hero-video]');
  const toggle = document.getElementById('hero-mobile-toggle');

  if (toggle && section) {
    const STORAGE_KEY = 'hero-mobile-media';
    const isDesktop = window.matchMedia('(min-width: 1024px)').matches;

    if (!isDesktop) {
      const updateState = (active: boolean) => {
        if (active) {
          section.setAttribute('data-mobile-media', '');
          toggle.textContent = 'Hide BG';
          if (video && !video.dataset.loaded) {
            const source = document.createElement('source');
            source.src = video.dataset.src ?? '';
            source.type = 'video/mp4';
            video.append(source);
            video.dataset.loaded = 'true';
            video.addEventListener('playing', () => {
              video.classList.remove('opacity-0');
            }, { once: true });
            video.load();
            video.play().catch(() => {});
          }
        } else {
          section.removeAttribute('data-mobile-media');
          toggle.textContent = 'Show BG';
        }
        localStorage.setItem(STORAGE_KEY, active ? '1' : '0');
      };

      const forceOn = new URLSearchParams(location.search).has('mobile-bg');
      updateState(forceOn || localStorage.getItem(STORAGE_KEY) === '1');
      toggle.addEventListener('click', () => {
        updateState(!section.hasAttribute('data-mobile-media'));
      });
    }
  }
</script>

<style is:inline>
  @media (min-width: 1024px) {
    .hero-fallback {
      background-image: var(--hero-fallback-image);
      background-position: center;
      background-repeat: no-repeat;
      background-size: cover;
    }
  }

  @media (max-width: 1023px) {
    [data-mobile-media] .hero-fallback {
      background-image: var(--hero-fallback-image);
      background-position: center;
      background-repeat: no-repeat;
      background-size: cover;
    }
  }

  video[data-hero-video]::-webkit-media-controls-start-playback-button {
    display: none !important;
    -webkit-appearance: none;
  }
</style>
