---
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
const isoStandards = [
  {
    code: "ISO 9001:2015",
    title: "Quality Management Systems",
  },
  {
    code: "ISO 14001:2015",
    title: "Environmental Management Systems",
  },
  {
    code: "ISO 45001:2018",
    title: "Occupational Health & Safety Management Systems",
  },
];
const directorCerts = [
  "Bachelor of Engineering (Honours)",
  "Diploma of Professional Practice (Engineering)",
  "ISO 9001, 14001 & 45001 Internal Auditor Training",
  "AFPA Sprayed Sealing Design",
  "Certificate IV in Work Health & Safety",
  "Certificate III in Emergency Response & Rescue",
  "Standard 11 — Surface & Underground Induction",
  "Maritime Security Identification Card (MSIC) — Current",
  "Airport Management System (AMS) Airside Induction — Current",
  "Rio Tinto (RTIO) Contractor Induction — Current",
  "BHP Contractor Induction — Current",
];
---

<section class="bg-base-50">
  <Wrapper variant="standard" class="py-24 lg:border-x lg:border-brand-gold">
    <div class="max-w-3xl">
      <Kicker class="text-base-600">Certifications & Credentials</Kicker>
      <Text
        tag="h2"
        variant="displayMD"
        class="font-medium tracking-tight mt-12 text-accent-950 text-balance"
      >
        Structured. Verified. Aligned.
      </Text>
      <Text tag="p" variant="textLG" class="text-base-600 mt-4">
        MESCo operates under a documented Integrated Management System (IMS)
        aligned with international standards. Our systems are developed,
        implemented, and maintained internally by qualified professionals.
      </Text>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">
      {
        isoStandards.map((standard) => (
          <div class="p-8 bg-white rounded">
            <Text
              tag="h3"
              variant="textXL"
              class="text-accent-900 font-medium"
            >
              {standard.code}
            </Text>
            <Text tag="p" variant="textBase" class="text-base-600 mt-2">
              {standard.title}
            </Text>
          </div>
        ))
      }
    </div>
    <div class="mt-16">
      <Text
        tag="h3"
        variant="textXL"
        class="text-accent-900 font-medium"
      >
        Director Certifications & Training
      </Text>
      <ul class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-3">
        {
          directorCerts.map((cert) => (
            <li class="flex items-start gap-3">
              <span class="text-brand-gold mt-1 shrink-0">&check;</span>
              <Text tag="span" variant="textBase" class="text-base-600">
                {cert}
              </Text>
            </li>
          ))
        }
      </ul>
    </div>
  </Wrapper>
</section>
