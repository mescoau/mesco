---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<section>
  <Wrapper variant="standard" class="py-24 lg:border-x lg:border-brand-gold">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
      <div>
        <Kicker class="text-base-500">Our Purpose</Kicker>
        <Text
          tag="h2"
          variant="displayMD"
          class="font-medium tracking-tight mt-8 text-accent-950 text-balance"
        >
          Simplifying compliance so teams can focus on delivery
        </Text>
        <Text tag="p" variant="textLG" class="text-base-600 mt-6">
          MESCo exists to strengthen the connection between project design,
          execution, and verification — ensuring that what is built on site
          matches what was intended in the specifications. We transform complex
          client and regulatory requirements into structured, practical systems
          that remove uncertainty, reduce rework, and give all stakeholders
          confidence in the evidence of compliance.
        </Text>
      </div>
      <div>
        <Kicker class="text-accent-600">Our Approach</Kicker>
        <Text
          tag="h2"
          variant="displayMD"
          class="font-medium tracking-tight mt-8 text-accent-950 text-balance"
        >
          Early involvement, structured systems, ongoing support
        </Text>
        <Text tag="p" variant="textLG" class="text-base-600 mt-6">
          MESCo's approach is grounded in structure, consistency and continual
          improvement. We apply the same principles that underpin ISO-based
          management systems — Plan, Do, Check, Act — to create order and
          confidence in project delivery. Our philosophy is built on proactive
          compliance versus reactive scrambling. Every problem has a solution.
        </Text>
      </div>
    </div>

    <div class="max-w-4xl text-balance mt-24">
      <Kicker class="text-base-600">The MESCo Difference</Kicker>
      <Text
        tag="h2"
        variant="displayLG"
        class="text-accent-900 font-medium mt-12"
      >
        A multi-disciplinary systems consultancy,
        <span class="text-brand-gold">
          operating under a documented IMS aligned with ISO 9001, ISO 45001 & ISO 14001
        </span>
      </Text>
      <Text tag="p" variant="textLG" class="text-base-600 mt-4">
        Every framework and workflow we deliver is controlled, traceable and
        tested in live project conditions by our leadership team. We support
        civil, mining and infrastructure contractors with systems that make
        compliance clear, documentation consistent and close-out simple.
      </Text>
    </div>
  </Wrapper>
</section>
