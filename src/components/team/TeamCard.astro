---
// Assets
import { Image } from "astro:assets";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
// Config
import { link } from "@/config/site";
const { url, name, image, role } = {
  url: link("/team/" + Astro.props.post.id),
  name: Astro.props.post.data.name,
  role: Astro.props.post.data.role,
  image: Astro.props.post.data.image.url,
};
---

<div class="relative">
  <a
    href={url}
    title={`View profile for ${name}`}
    aria-label={`View profile for ${name}`}
    class="absolute inset-0 z-10"></a>

  <div class="relative rounded">
    <Image
      src={image}
      alt={name}
      width={800}
      height={700}
      loading="lazy"
      decoding="async"
      class="object-cover object-top w-full aspect-4/3"
    />
  </div>

  <div class="mt-4">
    <Text tag="h3" variant="textXL" class="font-medium text-accent-900">
      {name}
    </Text>
    <Text tag="p" variant="textBase" class="text-base-600 mt-1">
      {role}
    </Text>
  </div>
</div>
