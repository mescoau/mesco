---
interface Props {
  birthday: string; // "MM-DD"
  hatX?: number;    // % from left (default 50)
  hatY?: number;    // % from top (default 0)
  hatRotate?: number; // degrees, positive = tilt right (default 0)
  hatSize?: number;  // % of container width (default 15)
}

const { birthday, hatX = 50, hatY = 0, hatRotate = 0, hatSize = 15 } = Astro.props;
---

<div
  class="birthday-hat"
  data-birthday={birthday}
  style={`left: ${hatX}%; top: ${hatY}%; --hat-rotate: ${hatRotate}deg; width: ${hatSize}%;`}
  aria-hidden="true"
>
  <svg
    viewBox="0 0 80 90"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    class="w-full h-full"
  >
    <!-- Hat cone -->
    <polygon points="40,8 10,90 70,90" fill="#e8345a" />
    <polygon points="40,8 10,90 70,90" fill="url(#hat-stripes)" />

    <!-- Diagonal stripes -->
    <defs>
      <pattern id="hat-stripes" x="0" y="0" width="80" height="20" patternUnits="userSpaceOnUse" patternTransform="rotate(-25)">
        <rect width="80" height="10" fill="rgba(255,255,255,0.13)" />
      </pattern>
    </defs>

    <!-- Polka dots -->
    <circle cx="35" cy="55" r="3.5" fill="#fbbf24" />
    <circle cx="48" cy="55" r="3.5" fill="#34d399" />
    <circle cx="40" cy="38" r="3.5" fill="#60a5fa" />
    <circle cx="30" cy="72" r="3" fill="#c084fc" />
    <circle cx="42" cy="72" r="3" fill="#fbbf24" />
    <circle cx="53" cy="72" r="3" fill="#60a5fa" />
    <circle cx="40" cy="25" r="2.5" fill="#fbbf24" />

    <!-- Pom-pom on top -->
    <circle cx="40" cy="8" r="6.5" fill="#fbbf24" />
    <circle cx="37" cy="6" r="2.5" fill="#fcd34d" />
    <circle cx="43" cy="5" r="1.5" fill="#fde68a" />
  </svg>
</div>

<style>
  .birthday-hat {
    display: none;
    position: absolute;
    transform: translate(-50%, -100%) rotate(var(--hat-rotate, 0deg));
    transform-origin: bottom center;
    z-index: 1;
    pointer-events: none;
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.25));
  }

  .birthday-hat[data-active] {
    display: block;
  }
</style>

<script>
  function checkBirthdays() {
    const hats = document.querySelectorAll<HTMLElement>('.birthday-hat');
    const now = new Date();
    const today = `${String(now.getMonth() + 1).padStart(2, '0')}-${String(now.getDate()).padStart(2, '0')}`;

    hats.forEach((hat) => {
      if (hat.dataset.birthday === today) {
        hat.setAttribute('data-active', '');
      }
    });
  }

  checkBirthdays();
  document.addEventListener('astro:page-load', checkBirthdays);
</script>
