---
import Seo from "@/components/fundations/head/Seo.astro";
import Meta from "@/components/fundations/head/Meta.astro";
import Favicons from "@/components/fundations/head/Favicons.astro";
import SchemaOrg from "@/components/fundations/head/SchemaOrg.astro";
import { orgSchema, websiteSchema } from "@/config/schema";

const { title, description } = Astro.props as {
  title?: string;
  description?: string;
};
---
<Seo title={title} description={description} />
<Meta />
<Favicons />
<SchemaOrg schema={[orgSchema, websiteSchema]} />
