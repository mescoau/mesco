---
import Seo from "@/components/fundations/head/Seo.astro";
import Meta from "@/components/fundations/head/Meta.astro";
import Favicons from "@/components/fundations/head/Favicons.astro";
import SchemaOrg from "@/components/fundations/head/SchemaOrg.astro";
import { orgSchema, websiteSchema } from "@/config/schema";

const { title, description } = Astro.props as {
  title?: string;
  description?: string;
};
const analyticsId = "G-PVDLGSPZHL";
---
<Meta />
<Seo title={title} description={description} />
<Favicons />
<SchemaOrg schema={[orgSchema, websiteSchema]} />
<script is:inline define:vars={{ analyticsId }}>
  (() => {
    const loadAnalytics = () => {
      if (window.__mescoAnalyticsLoaded) {
        return;
      }

      window.__mescoAnalyticsLoaded = true;
      window.dataLayer = window.dataLayer || [];
      window.gtag = window.gtag || function gtag() {
        window.dataLayer.push(arguments);
      };
      window.gtag("js", new Date());
      window.gtag("config", analyticsId);

      const script = document.createElement("script");
      script.async = true;
      script.src = `https://www.googletagmanager.com/gtag/js?id=${analyticsId}`;
      document.head.appendChild(script);
    };

    const scheduleAnalytics = () => {
      if ("requestIdleCallback" in window) {
        window.requestIdleCallback(loadAnalytics, { timeout: 3000 });
        return;
      }

      window.setTimeout(loadAnalytics, 2000);
    };

    if (document.readyState === "complete") {
      scheduleAnalytics();
    } else {
      window.addEventListener("load", scheduleAnalytics, { once: true });
    }

    ["pointerdown", "keydown", "touchstart"].forEach((eventName) => {
      window.addEventListener(eventName, loadAnalytics, {
        once: true,
        passive: true,
      });
    });
  })();
</script>
