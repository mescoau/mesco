---
/**
 * Renders a schema.org JSON-LD block.
 *
 * Pass a single schema node or an array — an array is wrapped in @graph.
 * The @context is always injected automatically.
 */
interface Props {
  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  schema: Record<string, any> | Record<string, any>[];
}

const { schema } = Astro.props;

const payload = Array.isArray(schema)
  ? { "@context": "https://schema.org", "@graph": schema }
  : { "@context": "https://schema.org", ...schema };

// Prevent </script> in string values from breaking the tag
const json = JSON.stringify(payload).replace(/<\/script>/gi, "<\\/script>");
---

<script type="application/ld+json" set:html={json} />
