---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import UnderlinedLink from "@/components/fundations/elements/UnderlinedLink.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
const cards = [
  {
    title: "Services",
    description:
      "See how MESCo supports WHS, quality, and project systems across the lifecycle.",
    href: "/services",
    cta: "Explore all services",
  },
  {
    title: "Case studies",
    description:
      "Explore MESCo project case studies and the systems behind each outcome.",
    href: "/case-studies",
    cta: "View case studies",
  },
  {
    title: "Our Team",
    description:
      "Meet the directors behind MESCo's engineering and compliance systems.",
    href: "/team",
    cta: "Meet the team",
  },
];
---

<section class="bg-accent-950 border-y border-brand-gold">
  <Wrapper variant="standard" class="py-24 lg:py-48 lg:border-x lg:border-brand-gold">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <Kicker class="text-base-300">Navigate</Kicker>
      <Text
        tag="h2"
        variant="displayLG"
        class="text-white font-medium lg:col-span-2"
      >
        Navigate to services, case studies, and our team to see how MESCo
        supports projects from planning through delivery.
      </Text>
    </div>
    <div
      class="grid gap-6 lg:gap-8 md:grid-cols-2 lg:grid-cols-3 mt-12 lg:mt-24"
    >
      {
        cards.map((card) => (
          <div>
            <div>
              <Text tag="h3" variant="textLG" class="font-medium text-base-100">
                {card.title}
              </Text>
              <Text
                tag="p"
                variant="textBase"
                class="text-base-400 mt-2 text-balance"
              >
                {card.description}
              </Text>
            </div>
            <UnderlinedLink variant="light" href={card.href} class="mt-12">
              {card.cta}
            </UnderlinedLink>
          </div>
        ))
      }
    </div>
  </Wrapper>
</section>
