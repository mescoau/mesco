---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Icons
import MapPin from "@/components/fundations/icons/MapPin.astro";
import Phone from "@/components/fundations/icons/Phone.astro";
import Envelpe from "@/components/fundations/icons/Envelope.astro";
const contactDetails = {
  email: "admin@mesco.au",
  phone: "+61 409 729 303",
  address: "Perth, WA",
};
const contactItems = [
  {
    label: "Location",
    value: [contactDetails.address],
    icon: "location",
  },
  {
    label: "Phone",
    value: [contactDetails.phone],
    href: `tel:${contactDetails.phone.replace(/[^\d+]/g, "")}`,
    icon: "phone",
  },
  {
    label: "Email",
    value: [contactDetails.email],
    href: `mailto:${contactDetails.email}`,
    icon: "mail",
  },
];
const inputClass = "w-full rounded border-brand-gold/15 bg-white px-4 py-3 h-12 text-accent-950 focus:border-brand-gold focus:ring-2 focus:ring-brand-gold duration-300 transition-all focus:border-transparent focus:outline-none";
const services = [
  "Project Start-Up Services",
  "Automated Engineering Systems & QA/QC Frameworks",
  "Engineering Administration & Project Support",
  "Health, Safety & Environmental Systems",
  "ISO Systems & Audit Support",
  "Project Close-Out Services",
  "Short-Term Fill-Ins & Technical Support",
  "Project Familiarisation & Delivery Tools",
];
---

<section>
  <Wrapper variant="standard" class="py-24 lg:border-x lg:border-brand-gold">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <div>
        <Kicker class="text-accent-600">Get in touch</Kicker>
        <Text
          tag="h2"
          variant="displaySM"
          class="font-medium tracking-tight text-base-900 mt-12 text-balance"
        >
          Talk directly with our directors.
        </Text>
        <Text tag="p" variant="textLG" class="text-base-600 mt-4">
          MESCo supports projects at every stage, from tender preparation
          through to final close-out. Whether you need a complete systems
          package, targeted technical support or on-site resourcing, we work
          with you to scope solutions that match your timeline and budget.
        </Text>
        <div class="mt-12 space-y-8 border-t border-base-200 pt-8">
          {
            contactItems.map((item) => (
              <div class="flex items-start gap-4">
                <span class="flex size-10 items-center justify-center rounded-full bg-brand-gold/10 text-accent-600">
                  {item.icon === "location" ? (
                    <MapPin size="sm" class="text-brand-gold" />
                  ) : item.icon === "phone" ? (
                    <Phone size="sm" class="text-brand-gold" />
                  ) : (
                    <Envelpe size="sm" class="text-brand-gold" />
                  )}
                </span>
                <div class="space-y-1">
                  <Text
                    tag="p"
                    variant="textBase"
                    class="font-medium  text-base-900"
                  >
                    {item.label}
                  </Text>
                  <Text
                    tag="p"
                    variant="textBase"
                    class="text-base-700 leading-relaxed"
                  >
                    {item.value.map((line, index) => (
                      <>
                        {item.href ? (
                          <a
                            href={
                              Array.isArray(item.href)
                                ? item.href[index] || item.href[0]
                                : item.href
                            }
                            class="transition-colors hover:text-brand-gold"
                          >
                            {line}
                          </a>
                        ) : (
                          line
                        )}
                        {index < item.value.length - 1 ? <br /> : ""}
                      </>
                    ))}
                  </Text>
                </div>
              </div>
            ))
          }
        </div>
      </div>
      <form action="https://forms-backend.withersco.workers.dev/api/forms/mesco" method="POST" class="bg-accent-950 rounded p-8">
        <Text
          tag="h3"
          variant="textLG"
          class="font-medium tracking-tight text-white"
        >
          Send us a message
        </Text>
        <Text tag="p" variant="textBase" class="text-base-400 mt-1">
          Share a few details and our directors will reach out within one
          business day.
        </Text>
        <div class="space-y-4 mt-12">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="space-y-2">
              <label for="contact-name" class="text-sm text-base-400 block">
                Name<span aria-hidden="true" class="text-brand-gold pointer-events-none">*</span>
              </label>
              <input id="contact-name" type="text" name="name" required autocomplete="name" class={inputClass} />
            </div>
            <div class="space-y-2">
              <label for="contact-company" class="text-sm text-base-400 block">
                Company
              </label>
              <input id="contact-company" type="text" name="company" autocomplete="organization" class={inputClass} />
            </div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="space-y-2">
              <label for="contact-role" class="text-sm text-base-400 block">
                Role
              </label>
              <input id="contact-role" type="text" name="role" class={inputClass} />
            </div>
            <div class="space-y-2">
              <label for="contact-email" class="text-sm text-base-400 block">
                Email<span aria-hidden="true" class="text-brand-gold pointer-events-none">*</span>
              </label>
              <input id="contact-email" type="email" name="email" required autocomplete="email" class={inputClass} />
            </div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="space-y-2">
              <label for="contact-phone" class="text-sm text-base-400 block">
                Phone
              </label>
              <input id="contact-phone" type="tel" name="phone" autocomplete="tel" class={inputClass} />
            </div>
            <div class="space-y-2">
              <label for="contact-stage" class="text-sm text-base-400 block">
                Project Stage
              </label>
              <select id="contact-stage" name="project_stage" class={inputClass}>
                <option value="">Select...</option>
                <option value="tender">Tender</option>
                <option value="pre-mobilisation">Pre-Mobilisation</option>
                <option value="active-project">Active Project</option>
                <option value="close-out">Close-Out</option>
              </select>
            </div>
          </div>
          <fieldset class="space-y-2">
            <legend class="text-sm text-base-400">Services of Interest</legend>
            <div class="grid grid-cols-1 gap-2 mt-2">
              {services.map((service) => (
                <label class="flex items-center gap-2 text-sm text-base-300 cursor-pointer">
                  <input type="checkbox" name="services" value={service} class="rounded border-brand-gold/15 bg-white text-brand-gold focus:ring-brand-gold" />
                  {service}
                </label>
              ))}
            </div>
          </fieldset>
          <div class="space-y-2">
            <label for="contact-message" class="text-sm text-base-400 block">
              Project Summary / Enquiry Details
            </label>
            <textarea
              id="contact-message"
              name="message"
              rows="4"
              class="w-full rounded border-brand-gold/15 bg-white px-4 py-3 text-accent-950 focus:border-brand-gold focus:ring-2 focus:ring-brand-gold duration-300 transition-all focus:border-transparent focus:outline-none"
            ></textarea>
          </div>
          <fieldset class="space-y-2">
            <legend class="text-sm text-base-400">Preferred Contact Method</legend>
            <div class="flex gap-6 mt-2">
              <label class="flex items-center gap-2 text-sm text-base-300 cursor-pointer">
                <input type="radio" name="preferred_contact" value="phone" class="border-brand-gold/15 bg-white text-brand-gold focus:ring-brand-gold" />
                Phone
              </label>
              <label class="flex items-center gap-2 text-sm text-base-300 cursor-pointer">
                <input type="radio" name="preferred_contact" value="email" class="border-brand-gold/15 bg-white text-brand-gold focus:ring-brand-gold" />
                Email
              </label>
            </div>
          </fieldset>
        </div>

        <Button size="lg" type="submit" variant="muted" class="w-full mt-8">
          Submit
        </Button>
      </form>
    </div>
  </Wrapper>
</section>
